# Supabase — populate once real backend integration begins.
# See src/lib/supabase-client.ts. Mock UI/data flows do not read these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The app's own public base URL — never a Supabase URL. Used by
# src/lib/server/invite-user-action.ts to build the "Generate invite link"
# link (${NEXT_PUBLIC_APP_URL}/accept-invite?...) so an admin only ever
# copies a JIRITA link, never a supabase.co one. e.g. http://localhost:3000,
# https://staging.jirita.com, https://app.jirita.com.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — never prefix with NEXT_PUBLIC_. Used exclusively by
# src/lib/server/invite-user-action.ts (a Server Action) to send real
# invite emails and provision profiles/organization_memberships via the
# Supabase Auth Admin API. Get it from Project Settings → API → service_role.
# Never commit the real value; never reference it from a "use client" file.
SUPABASE_SERVICE_ROLE_KEY=

# GitHub OAuth — Repository Integration's real "Connect GitHub" flow
# (src/app/api/integrations/github/connect|callback/route.ts,
# src/lib/server/github-repository-connection*.ts). Server-only; never
# prefix with NEXT_PUBLIC_, never reference from a "use client" file.
#
# From a GitHub OAuth App (github.com/settings/developers → OAuth Apps →
# New OAuth App): Homepage URL = ${NEXT_PUBLIC_APP_URL}, Authorization
# callback URL = ${NEXT_PUBLIC_APP_URL}/api/integrations/github/callback.
#
# NOTE: this is intentionally GITHUB_CLIENT_ID/GITHUB_CLIENT_SECRET, not
# GITHUB_OAUTH_CLIENT_ID/GITHUB_OAUTH_CLIENT_SECRET — matches the names
# actually used elsewhere in this environment's own .env.local; the code
# reads exactly these two.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/integrations/github/callback

# AES-256-GCM key for encrypting a connected GitHub account's access token
# at rest (project_repository_connections.access_token_ciphertext/_iv/
# _auth_tag — see src/lib/server/github-token-crypto.ts). Must be base64
# and decode to exactly 32 bytes, e.g.: openssl rand -base64 32
GITHUB_TOKEN_ENCRYPTION_KEY=
