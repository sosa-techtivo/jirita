# Supabase — populate once real backend integration begins.
# See src/lib/supabase-client.ts. Mock UI/data flows do not read these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The app's own public base URL — never a Supabase URL. Used by
# src/lib/server/invite-user-action.ts to build the "Generate invite link"
# link (${NEXT_PUBLIC_APP_URL}/accept-invite?...) so an admin only ever
# copies a JIRITA link, never a supabase.co one. e.g. http://localhost:3000,
# https://staging.jirita.com, https://app.jirita.com.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — never prefix with NEXT_PUBLIC_. Used exclusively by
# src/lib/server/invite-user-action.ts (a Server Action) to send real
# invite emails and provision profiles/organization_memberships via the
# Supabase Auth Admin API. Get it from Project Settings → API → service_role.
# Never commit the real value; never reference it from a "use client" file.
SUPABASE_SERVICE_ROLE_KEY=
